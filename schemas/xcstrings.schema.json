{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XCStrings String Catalog",
  "type": "object",
  "required": ["sourceLanguage", "strings"],
  "additionalProperties": false,

  "properties": {
    "sourceLanguage": {
      "type": "string",
      "description": "Base development language (e.g., 'en', 'en-US')",
      "pattern": "^[a-z]{2}(-[A-Za-z0-9]+)*$"
    },

    "version": {
      "type": "string",
      "description": "XCStrings format version"
    },

    "strings": {
      "type": "object",
      "description": "Localized string entries",
      "additionalProperties": {
        "$ref": "#/definitions/stringEntry"
      }
    }
  },

  "definitions": {

    "stringEntry": {
      "type": "object",
      "description": "Single localized string definition",
      "additionalProperties": false,
      "properties": {

        "comment": {
          "type": "string",
          "description": "Developer comment for translators"
        },

        "isCommentAutoGenerated": {
          "type": "boolean",
          "description": "Whether comment was automatically generated"
        },

        "extractionState": {
          "type": "string",
          "enum": ["manual", "automatic"],
          "description": "Indicates extraction origin"
        },

        "localizations": {
          "type": "object",
          "description": "Language-specific translations",
          "patternProperties": {
            "^[a-z]{2}(-[A-Za-z0-9]+)*$": {
              "$ref": "#/definitions/localization"
            }
          },
          "additionalProperties": false
        }
      }
    },

    "localization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {

        "stringUnit": {
          "$ref": "#/definitions/stringUnit"
        }
      },
      "required": ["stringUnit"]
    },

    "stringUnit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {

        "state": {
          "type": "string",
          "enum": [
            "new",
            "translated",
            "needs-review",
            "untranslated"
          ],
          "description": "Translation state"
        },

        "value": {
          "type": "string",
          "description": "Localized string value"
        }
      },
      "required": ["value"]
    }
  }
}